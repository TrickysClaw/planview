# Environment Variables — NEVER commit this file
# Copy to .env and fill in values

NODE_ENV=development
PORT=4000

# CORS — allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.111:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# API Keys (for future paid tier)
# API_KEY_SALT=generate-a-random-string-here

# Database (when ready)
# DATABASE_URL=postgresql://user:pass@localhost:5432/planview

# Redis (when ready)
# REDIS_URL=redis://localhost:6379
